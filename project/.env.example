# Langfuse Observability (optional)
# Set LANGFUSE_ENABLED=true and provide your API keys to enable tracing.
# Get your keys from https://cloud.langfuse.com or your self-hosted instance.
LLM_PROVIDER=openai_compatible
LLM_MODEL=deepseek-v4-flash
OPENAI_COMPATIBLE_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ali_api_key=your-aliyun-api-key

# Embedding model used by Qdrant dense retrieval.
EMBEDDING_PROVIDER=openai_compatible
DENSE_MODEL=tongyi-embedding-vision-plus-2026-03-06
EMBEDDING_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=your-dashscope-api-key

# Retrieval pipeline tuning.
RETRIEVAL_CANDIDATE_TOP_K=12
RETRIEVAL_FINAL_TOP_K=5
RETRIEVAL_MAX_TOOL_LIMIT=10
TRACE_MAX_CANDIDATES=12

# Optional rerank layer.
RERANK_ENABLED=true
RERANK_PROVIDER=zhipu
RERANK_MODEL=rerank
RERANK_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4/rerank
ZP_api_key=your-zhipu-api-key
RERANK_TOP_K=8
RERANK_SCORE_THRESHOLD=0
RERANK_TIMEOUT_SECONDS=30
RERANK_MAX_DOCUMENT_CHARS=4000

# Final context packing.
CONTEXT_MAX_CHUNKS=5
CONTEXT_MAX_TOKENS=3000
CONTEXT_DEDUP_BY_PARENT=true
CONTEXT_DEDUP_BY_CONTENT=true

# Optional local Ollama fallback:
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=qwen3:4b-instruct-2507-q4_K_M

LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=http://localhost:3000
